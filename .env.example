# ── Network ───────────────────────────────────────────────────────
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
GMX_ORACLE_URL=https://arbitrum-api.gmxinfra.io
CHAIN_ID=42161

# ── Hot wallet (NEVER COMMIT A REAL KEY) ──────────────────────────
# Single EOA "E" = GMX trader + Lagoon valuationManager + curator/safe.
# E = 0xee94E1A5534A70231DaEE670b51fEC50AC032b6A
# Startup aborts unless privateKeyToAccount(HOT_PK).address === EXPECTED_EOA.
# IMPORTANT: E must hold ZERO personal USDC — NAV idle = balanceOf(E), so any USDC
# on E is counted as vault NAV. Keep only ETH on E (gas + GMX execution fee). GMX
# collateral is drawn from the already-deposited USDC that settle moves into E.
HOT_PK=
EXPECTED_EOA=0xee94E1A5534A70231DaEE670b51fEC50AC032b6A

# ── Lagoon vault (Arbitrum One — deployed; both roles = E) ─────────
VAULT_ADDRESS=0x7f6c5ed71ca969168247958057fcfe06c68ad5a2
SILO_ADDRESS=

# ── GMX V2 contracts (Arbitrum One — verified 2026-06-14) ─────────
# Defaults are baked into config.ts; override only if the SDK config diverges.
GMX_EXCHANGE_ROUTER=0x1C3fa76e6E1088bCE750f23a5BFcffa1efEF6A41
GMX_ROUTER=0x7452c558d45f8afC8c83dAe62C3f8A5BE19c71f6
GMX_ORDER_VAULT=0x31eF83a530Fde1B38EE9A18093A333D8Bbbc40D5
GMX_DATASTORE=0xFD70de6b91282D8017aA4E741e9Ae325CAb992d8
GMX_READER=0x470fbC46bcC0f16532691Df360A07d8Bf5ee0789
GMX_REFERRAL_STORAGE=0xe6fab3F0c7199b0d34d7FbE83394fc0e0D06e99d
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
WETH_ADDRESS=0x82aF49447D8a07e3bd95BD0d56f35241523fBab1

# ── Trading params ────────────────────────────────────────────────
TARGET_LEVERAGE=2
MIN_ORDER_USD=15
MAX_TOTAL_NOTIONAL_USD=200
ACCEPTABLE_PRICE_SLIPPAGE_BPS=150

# ── Signal source ─────────────────────────────────────────────────
# mock | hlnative
SIGNAL_SOURCE=mock
HLNATIVE_BASE_URL=http://localhost:4000
# Rescales hlnative's AUM-sized notionals down to this GMX vault.
MIRROR_SCALE=1

# ── NAV guards ────────────────────────────────────────────────────
STRICT_FIRST_NAV_ZERO=true
NAV_DIVERGENCE_MAX_BPS=1000

# ── Operational ───────────────────────────────────────────────────
# Master safety switch: true = simulate only, never broadcast a tx.
DRY_RUN=true
NODE_ENV=development
TRADE_CRON=*/2 * * * *
NAV_CRON=*/2 * * * *
LOG_LEVEL=info
PORT=8080
