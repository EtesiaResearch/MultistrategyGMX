# Backend NAV-oracle base URL (GET /status, /history). Local dev: http://localhost:8080.
# Railway: set to the deployed backend URL (with https://, no trailing slash).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# ── Deposit / withdraw (wallet) ───────────────────────────────────
# All optional — sensible defaults are baked in.
# Vault proxy override (defaults to the Arbitrum vault in @etesia/shared).
# NEXT_PUBLIC_VAULT_ADDRESS=0x7f6c5ed71ca969168247958057fcfe06c68ad5a2
# Private Arbitrum RPC for wallet reads (public endpoint rate-limits).
# NEXT_PUBLIC_ARBITRUM_RPC=
# Block explorer base (defaults to arbiscan.io).
# NEXT_PUBLIC_EXPLORER_URL=https://arbiscan.io
# Lagoon GraphQL API for the withdraw countdown.
# NEXT_PUBLIC_LAGOON_API_URL=https://api.lagoon.finance/query
# Mirror the backend NAV_CRON cadence for the deposit settlement countdown (minutes).
# NEXT_PUBLIC_SETTLE_CYCLE_MINUTES=15
